{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "env": {
                "DB__HOST": "127.0.0.1",
                "REDIS__HOST": "127.0.0.1",
                "OTLP_ENDPOINT": "http://127.0.0.1:4317"
            }
        }
    ]
}