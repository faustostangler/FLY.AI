      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "axisLabel": "Sincronizações Realizadas",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "increase(companies_synced_total{status=\"success\", environment=~\"^$environment$\", version=~\"^$version$\"}[1m])",
          "format": "time_series",
          "legendFormat": "Sucesso",
          "refId": "A"
        }
      ],
      "title": "Sucesso nas Operações de Sincronização",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "DS_PROMETHEUS"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
