      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(increase(domain_data_validation_errors_total{environment=~\"^$environment$\"}[1m])) by (reason)",
          "format": "time_series",
          "legendFormat": "{{reason}}",
          "refId": "A"
