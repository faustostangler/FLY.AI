# ============================================================
# FLY.AI - Environment Configuration (SOTA Standard)
# ============================================================
COMPOSE_PROJECT_NAME=fly
APP_ENV=development
APP__DEBUG=True
LOG_LEVEL=INFO

# ============================================================
# EXTERNAL PORTS (Host machine access)
# ============================================================
API_EXTERNAL_PORT=8001
DB_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379
PGADMIN_EXTERNAL_PORT=5050
PROMETHEUS_EXTERNAL_PORT=9090
GRAFANA_EXTERNAL_PORT=3000

# ============================================================
# INTERNAL PORTS (Container target ports)
# ============================================================
API_INTERNAL_PORT=8000
DB_INTERNAL_PORT=5432
REDIS_INTERNAL_PORT=6379
PGADMIN_INTERNAL_PORT=80
PROMETHEUS_INTERNAL_PORT=9090
GRAFANA_INTERNAL_PORT=3000

# ============================================================
# INFRASTRUCTURE IMAGES (Versions/Tags)
# Default is 'latest' for all services as per SOTA requirements
# ============================================================
POSTGRES_VERSION=latest
REDIS_VERSION=latest
PGADMIN_VERSION=latest
PROMETHEUS_VERSION=latest
GRAFANA_VERSION=latest

# ============================================================
# SECRETS: DATABASE
# ============================================================
POSTGRES_USER=fly_user_stangler
POSTGRES_PASSWORD=fly_pass_stangler_secure_123!
POSTGRES_DB=fly_b3

# CACHE
# The REDIS__URL is assembled dynamically by the docker-compose.yml.
# ============================================================

# ============================================================
# SECRETS: OBSERVABILITY
# ============================================================
PGADMIN_EMAIL=admin@fly.ai
PGADMIN_PASSWORD=admin_pass_secure
GRAFANA_PASSWORD=observability_pass_secure

# ============================================================
# B3 SCRAPER SETTINGS (Optional Overrides)
# ============================================================
B3__HEADLESS=True
B3__MAX_CONCURRENCY=50
