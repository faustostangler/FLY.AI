# Project Metadata
COMPOSE_PROJECT_NAME=fly
PROJECT_NETWORK_NAME=net
APP_ENV=development
APP__DEBUG=True
LOG_LEVEL=INFO

# Docker Compose Profiles
# Default (API, Worker, DB, Cache)
COMPOSE_PROFILES=
# DB Admin (+ pgAdmin)
# COMPOSE_PROFILES=admin
# Performance e observability (+ Prometheus, Grafana)
# COMPOSE_PROFILES=observability

# Infrastructure Policy
DOCKER_RESTART_POLICY=unless-stopped
DOCKER_BIND_IP=0.0.0.0
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
DOCKER_BUILD_TARGET=runtime
METRICS_RETENTION_TIME=15d

# Resource Constraints (SOTA Protection)
API_MEM_LIMIT=512M
API_CPU_LIMIT=0.5
WORKER_COMPANY_MEM_LIMIT=2G
WORKER_COMPANY_CPU_LIMIT=1.0
DB_MEM_LIMIT=1G
DB_CPU_LIMIT=1.0
CACHE_MEM_LIMIT=256M
DB_ADMIN_MEM_LIMIT=256M

# Healthcheck Tuning
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3

# API Service
API_SERVICE_NAME=api
API_IMAGE_NAME=api
API_IMAGE_VERSION=latest
API_INTERNAL_PORT=8000
API_EXTERNAL_PORT=8001

# Worker Service
WORKER_COMPANY_SERVICE_NAME=worker_company_data_source
WORKER_COMPANY_IMAGE_NAME=worker-company
WORKER_COMPANY_IMAGE_VERSION=latest

# Database Service
DB_SERVICE_NAME=db
DB_IMAGE_NAME=postgres
DB_IMAGE_VERSION=latest
DB_FOLDER=/var/lib/postgresql
DB_INTERNAL_PORT=5432
DB_EXTERNAL_PORT=5432
DB__USER=fly_user_stangler
DB__PASSWORD=fly_pass_stangler_secure_123!
DB__NAME=fly_b3
DB__HOST=localhost
DB__PORT=5432
DB__CONNECTION_TIMEOUT=60

# Cache Service
CACHE_SERVICE_NAME=cache
CACHE_IMAGE_NAME=redis
CACHE_IMAGE_VERSION=latest
CACHE_FOLDER=/data
CACHE_INTERNAL_PORT=6379
CACHE_EXTERNAL_PORT=6379

# DB Admin
DB_ADMIN_SERVICE_NAME=db_admin
DB_ADMIN_IMAGE_NAME=dpage/pgadmin4
DB_ADMIN_IMAGE_VERSION=latest
DB_ADMIN_FOLDER=/var/lib/pgadmin
DB_ADMIN_INTERNAL_PORT=80
DB_ADMIN_EXTERNAL_PORT=5050
DB_ADMIN_EMAIL=admin@fly.ai
DB_ADMIN_PASSWORD=admin_pass_secure

# Metrics
METRICS_SERVICE_NAME=metrics
METRICS_IMAGE_NAME=prom/prometheus
METRICS_IMAGE_VERSION=latest
METRICS_FOLDER=/prometheus
METRICS_INTERNAL_PORT=9090
METRICS_EXTERNAL_PORT=9090

# Observability
OBSERVABILITY_SERVICE_NAME=observability
OBSERVABILITY_IMAGE_NAME=grafana/grafana
OBSERVABILITY_IMAGE_VERSION=latest
OBSERVABILITY_FOLDER=/var/lib/grafana
OBSERVABILITY_INTERNAL_PORT=3000
OBSERVABILITY_EXTERNAL_PORT=3000
OBSERVABILITY_PASSWORD=observability_pass_stangler

# Scraper Settings
B3__HEADLESS=True
B3__MAX_CONCURRENCY=50
