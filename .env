# Project Metadata
COMPOSE_PROJECT_NAME=fly
PROJECT_NETWORK_NAME=fly-net
APP_ENV=development
APP__DEBUG=True
LOG_LEVEL=INFO

# Docker Compose Profiles
# Options: "observability" | "debug" | "admin" | "observability,debug" | "" (Core only)
COMPOSE_PROFILES=observability

# Infrastructure Policy
DOCKER_RESTART_POLICY=unless-stopped
DOCKER_BIND_IP=0.0.0.0
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
DOCKER_BUILD_TARGET=runtime
PROMETHEUS_RETENTION_TIME=15d

# Resource Constraints (SOTA Protection)
API_MEM_LIMIT=512M
API_CPU_LIMIT=0.5
WORKER_MEM_LIMIT=2G
WORKER_CPU_LIMIT=1.0
DB_MEM_LIMIT=1G
DB_CPU_LIMIT=1.0
CACHE_MEM_LIMIT=256M
DB_ADMIN_MEM_LIMIT=256M

# Healthcheck Tuning
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3

# API Service
API_SERVICE_NAME=api
API_IMAGE_NAME=fly-api
API_VERSION=latest
API_INTERNAL_PORT=8000
API_EXTERNAL_PORT=8001

# Worker Service
WORKER_SERVICE_NAME=worker_company_data_source
WORKER_IMAGE_NAME=fly-worker
WORKER_VERSION=latest

# Database Service
DB_SERVICE_NAME=db
DB_IMAGE_NAME=postgres
POSTGRES_VERSION=latest
DB_INTERNAL_PORT=5432
DB_EXTERNAL_PORT=5432
VOLUME_DB_DATA=fly-db-data
DB__USER=fly_user_stangler
DB__PASSWORD=fly_pass_stangler_secure_123!
DB__NAME=fly_b3
DB__HOST=localhost
DB__PORT=5432
DB__CONNECTION_TIMEOUT=60

# Cache Service
CACHE_SERVICE_NAME=cache
CACHE_IMAGE_NAME=redis
REDIS_VERSION=latest
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379
VOLUME_CACHE_DATA=fly-cache-data

# DB Admin
DB_ADMIN_SERVICE_NAME=db_admin
DB_ADMIN_IMAGE_NAME=dpage/pgadmin4
PGADMIN_VERSION=latest
PGADMIN_INTERNAL_PORT=80
PGADMIN_EXTERNAL_PORT=5050
PGADMIN_EMAIL=admin@fly.ai
PGADMIN_PASSWORD=admin_pass_secure
VOLUME_DB_ADMIN_DATA=fly-pgadmin-data

# Metrics
METRICS_SERVICE_NAME=metrics
METRICS_IMAGE_NAME=prom/prometheus
PROMETHEUS_VERSION=latest
PROMETHEUS_INTERNAL_PORT=9090
PROMETHEUS_EXTERNAL_PORT=9090
VOLUME_METRICS_DATA=fly-prometheus-data

# Observability
OBSERVABILITY_SERVICE_NAME=observability
OBSERVABILITY_IMAGE_NAME=grafana/grafana
GRAFANA_VERSION=latest
GRAFANA_INTERNAL_PORT=3000
GRAFANA_EXTERNAL_PORT=3000
GRAFANA_PASSWORD=observability_pass_secure
VOLUME_OBSERVABILITY_DATA=fly-grafana-data

# Scraper Settings
B3__HEADLESS=True
B3__MAX_CONCURRENCY=50
